@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "_LayoutDashboard";
    var keyword = ViewBag.Keyword as string ?? "";
    int tongUser = ViewBag.TongUser ?? 0;
    int tongAdmin = ViewBag.TongAdmin ?? 0;
    var currentUserId = int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center" style="width:56px;height:56px;">
                    <i class="bi bi-people-fill fs-3"></i>
                </div>
                <div class="ms-3">
                    <div class="text-muted small">Tổng số người dùng</div>
                    <div class="fs-4 fw-bold">@tongUser</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-warning bg-opacity-10 text-warning d-flex align-items-center justify-content-center" style="width:56px;height:56px;">
                    <i class="bi bi-shield-lock-fill fs-3"></i>
                </div>
                <div class="ms-3">
                    <div class="text-muted small">Quản trị viên</div>
                    <div class="fs-4 fw-bold">@tongAdmin</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center" style="width:56px;height:56px;">
                    <i class="bi bi-person-check-fill fs-3"></i>
                </div>
                <div class="ms-3">
                    <div class="text-muted small">Người dùng thường</div>
                    <div class="fs-4 fw-bold">@(tongUser - tongAdmin)</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 d-flex flex-wrap align-items-center justify-content-between gap-2 py-3">
        <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i>Danh sách người dùng</h5>
        <div class="d-flex gap-2 flex-wrap">
            <form method="get" class="d-flex" style="max-width:320px;">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="q" value="@keyword" class="form-control" placeholder="Tìm theo email hoặc tên..." />
                    @if (!string.IsNullOrEmpty(keyword))
                    {
                        <a href="@Url.Action("Users")" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
                    }
                    <button type="submit" class="btn btn-outline-primary">Tìm</button>
                </div>
            </form>
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Thêm người dùng</a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Người dùng</th>
                        <th>Email</th>
                        <th>Ngày đăng ký</th>
                        <th class="text-center">Vai trò</th>
                        <th class="text-end">Số chi tiêu</th>
                        <th class="text-end">Tổng chi tiêu</th>
                        <th class="text-center pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var u = (QuanLyChiTieu.Models.NguoiDung)item.User;
                        var isAdmin = u.LoaiTaiKhoan == 1;
                        var isCurrent = u.Id == currentUserId;
                        var avatar = !string.IsNullOrEmpty(u.AvatarUrl)
                            ? u.AvatarUrl
                            : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(u.HoTen ?? u.Email)}&background=4BC0C0&color=fff";
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@avatar" alt="avatar" class="rounded-circle me-2" style="width:40px;height:40px;object-fit:cover;" />
                                    <div>
                                        <div class="fw-semibold">@(u.HoTen ?? "(Chưa đặt tên)")</div>
                                        <div class="text-muted small">ID: @u.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td>@u.Email</td>
                            <td>@(u.NgayDangKy?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="text-center">
                                @if (isAdmin)
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-shield-lock-fill me-1"></i>Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">User</span>
                                }
                            </td>
                            <td class="text-end">@item.SoChiTieu</td>
                            <td class="text-end fw-semibold">@(((decimal)item.TongChiTieu).ToString("N0")) ₫</td>
                            <td class="text-center pe-4">
                                <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary" title="Sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                @if (isCurrent)
                                {
                                    <span class="badge bg-info text-dark ms-1">Bạn</span>
                                }
                                else
                                {
                                    <form asp-action="ToggleRole" asp-route-id="@u.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="Đổi vai trò">
                                            <i class="bi bi-arrow-repeat"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Xóa @u.Email và toàn bộ dữ liệu liên quan?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                Không tìm thấy người dùng nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
