@model QuanLyChiTieu.ViewModels.AdminUserViewModel
@{
    ViewData["Title"] = "Thêm người dùng";
    Layout = "_LayoutDashboard";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3 d-flex align-items-center justify-content-between">
                <h5 class="mb-0"><i class="bi bi-person-plus-fill me-2"></i>Thêm người dùng mới</h5>
                <a asp-action="Users" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="vidu@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="HoTen" class="form-label"></label>
                            <input asp-for="HoTen" class="form-control" placeholder="Nguyễn Văn A" />
                            <span asp-validation-for="HoTen" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MatKhau" class="form-label"></label>
                            <input asp-for="MatKhau" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="MatKhau" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="XacNhanMatKhau" class="form-label"></label>
                            <input asp-for="XacNhanMatKhau" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Vai trò</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="LoaiTaiKhoan" id="role-user" value="0" checked="@(Model.LoaiTaiKhoan == 0)" />
                                    <label class="form-check-label" for="role-user">
                                        <span class="badge bg-secondary">User</span> Người dùng thường
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="LoaiTaiKhoan" id="role-admin" value="1" checked="@(Model.LoaiTaiKhoan == 1)" />
                                    <label class="form-check-label" for="role-admin">
                                        <span class="badge bg-warning text-dark"><i class="bi bi-shield-lock-fill me-1"></i>Admin</span> Quản trị viên
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Users" class="btn btn-outline-secondary">Hủy</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Tạo tài khoản</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
